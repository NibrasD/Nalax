# =============================================================================
# Nalax Project - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# =============================================================================

# Deployer private key (WITHOUT 0x prefix)
# Generate with: cast wallet new
DEPLOYER_PRIVATE_KEY=your_private_key_here

# Optional: Infura API key for Base mainnet access
INFURA_API_KEY=your_infura_key_here

# Optional: CoinMarketCap API key for gas reporter
CMC_API_KEY=your_cmc_key_here

# =============================================================================
# Contract Addresses
# =============================================================================

# Horizen ZEN ERC-20 Addresses
# Mainnet: 0xf43eB8De897Fbc7F2502483B2Bef7Bb9EA179229
# Testnet: Check Horizen docs for latest testnet ZEN address
ZEN_TOKEN_MAINNET=0xf43eB8De897Fbc7F2502483B2Bef7Bb9EA179229
ZEN_TOKEN_TESTNET=0xYourTestnetZENAddressHere

# =============================================================================
# Horizen L3 Endpoints
# =============================================================================
# Testnet RPC
HORIZEN_TESTNET_RPC=https://horizen-testnet.rpc.caldera.xyz/http
# Testnet Explorer
HORIZEN_TESTNET_EXPLORER=https://horizen-testnet.explorer.caldera.xyz

# =============================================================================
# Production TEE/HCCE Configuration (Placeholder)
# =============================================================================
# In production, these would be the Horizen Confidential Compute Environment
# endpoints for secure reveal execution
HCCE_ENDPOINT=https://hcce.horizen.io/api/v1/reveal
HCCE_API_KEY=your_hcce_api_key_here

# =============================================================================
# ZK Verification (Placeholder)
# =============================================================================
# Horizen zkVerify precompile address (when available)
ZKVERIFY_PRECOMPILE_ADDRESS=0x00000000000000000000000000000000000000FF
